<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewsApp.Pages.NewsHomePage"
             Title="News Home">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Header -->
        <Label Grid.Row="0"
               Text="News Pilot"
               FontSize="Title"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Padding="20"/>

        <!-- Categories -->
        <CollectionView Grid.Row="1"
                        Margin="5"
                        x:Name="CvCategories"
                        HeightRequest="100"
                        SelectionMode="Single"
                        SelectionChanged="CvCategories_SelectionChanged">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="5" WidthRequest="150">
                        <VerticalStackLayout Padding="0" Spacing="0" VerticalOptions="Center">
                            <Image HeightRequest="50"
                                   Aspect="AspectFit"
                                   Source="{Binding ImageUrl}"/>
                            <Label FontSize="Medium"
                                   HorizontalOptions="Center"
                                   Text="{Binding Name}"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- News Articles -->
        <CollectionView Grid.Row="2"
                        Margin="5"
                        x:Name="CvNews"
                        SelectionMode="Single"
                        SelectionChanged="CvNews_SelectionChanged">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="5" Margin="5">
                        <VerticalStackLayout Padding="5" Spacing="0" VerticalOptions="Center">
                            <Image HeightRequest="200"
                                   Aspect="Fill"
                                   Source="{Binding Image}"/>
                            <Label FontSize="Medium"
                                   Text="{Binding Title}"
                                   LineBreakMode="WordWrap"
                                   MaxLines="3"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>